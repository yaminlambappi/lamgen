SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://postgres:postgres@db:5432/lamgen_db
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1

# ── AI Provider: Google Cloud Vertex AI (recommended for production) ──────────
# Uses Google Cloud credits — no per-key quota limits.
VERTEX_AI=true
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to service account JSON key file (leave blank to use ADC / gcloud auth)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Model: gemini-2.5-flash (fast) | gemini-2.5-pro (quality)
GEMINI_MODEL=gemini-2.5-flash

# ── AI Provider: Gemini API Studio (alternative, free tier) ──────────────────
# Only used when VERTEX_AI=false. Key must start with "AIza".
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Other providers (optional fallbacks) ─────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
