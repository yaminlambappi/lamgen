SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://postgres:postgres@db:5432/lamgen_db
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model — use claude-haiku-3-5 for cheapest, claude-sonnet-4-5 for quality
CLAUDE_MODEL=claude-sonnet-4-5

# Token limits
CLAUDE_MAX_TOKENS=4000
CLAUDE_MAX_TOKENS_PER_JOB=40000

# Set to True during development to skip real API calls entirely
CLAUDE_MOCK_MODE=True

# Generation behaviour
# GENERATION_MODE: economy | standard | quality
GENERATION_MODE=standard
ASSIGNMENT_TYPE_DEFAULT=essay
CITATION_STYLE_DEFAULT=APA
WRITING_TONE_DEFAULT=critical_analytical

# Section detection: auto | fixed
SECTION_MODE=auto
SECTION_COUNT_DEFAULT=5

# Soft budget warning per job (cents)
MAX_GENERATION_BUDGET_CENTS=25
